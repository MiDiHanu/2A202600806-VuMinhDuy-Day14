# Sao chép file này thành .env và điền API key của bạn.
# KHÔNG commit file .env lên GitHub.

# Gemini API key (lấy tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# (Tùy chọn) chọn model cho từng vai trò. Mặc định đã set trong code.
# JUDGE_MODEL_A=gemini-2.5-flash
# JUDGE_MODEL_B=gemini-2.5-pro
# AGENT_MODEL=gemini-2.5-flash
# SDG_MODEL=gemini-2.5-flash
